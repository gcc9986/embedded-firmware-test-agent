# Feishu custom bot webhook. Leave empty to disable sending.
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# Optional OpenAI-compatible LLM endpoint. If unset, the built-in rule engine is used.
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Optional default repository for webhook mode.
AGENT_DEFAULT_REPO=.
AGENT_DEFAULT_CONFIG=configs/demo.json
